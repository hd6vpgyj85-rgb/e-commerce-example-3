rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null;
    }

    // Catalog data (names, prices, images) isn't sensitive — reads are public
    // so the storefront's queries don't have to structurally match a rule
    // that depends on "visible" (which would force composite indexes for
    // every query that also filters/sorts by another field). The app itself
    // only ever displays documents with visible == true.
    match /collections/{collectionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(
        ['items', 'total', 'status', 'customerPhone', 'contactMessage']
      ) && request.resource.data.total is number
        && request.resource.data.total > 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.customerPhone is string
        && request.resource.data.customerPhone.size() > 0;
      allow read, update, delete: if isAdmin();
    }
  }
}
